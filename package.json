{
  "name": "labreserve",
  "version": "1.0.0",
  "private": true,
  "description": "LabReserve - 高校实验室预约管理系统",
  "scripts": {
    "dev:web": "pnpm -F @labreserve/web dev",
    "build:web": "pnpm -F @labreserve/web build",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "format": "prettier --write \"**/*.{ts,vue,js,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,vue,js,json,md,yaml,yml}\"",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/node": "^22.15.29",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1"
  },
  "lint-staged": {
    "*.{ts,vue,js}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml,css,scss}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.9",
  "dependencies": {
    "vue-eslint-parser": "^10.4.1"
  }
}
